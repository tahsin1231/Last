rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "minecatika@gmail.com");
    }

    // Helper to check if user owns the document (via firebaseUid field)
    function isDocOwner() {
      return isAuthenticated() && resource.data.firebaseUid == request.auth.uid;
    }

    match /settings/config {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{telegramId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
        request.resource.data.firebaseUid == request.auth.uid &&
        request.resource.data.telegramId == telegramId;
      
      allow update: if isAdmin() || isDocOwner() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['earnings', 'referralCount', 'referralCounted']) &&
        (
          // Referral increment
          (request.resource.data.referralCount == resource.data.referralCount + 1) ||
          // Marking referral as counted
          (request.resource.data.referralCounted == true)
        )
      );
    }

    match /withdrawals/{withdrawalId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }
  }
}
